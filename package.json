{
  "name": "excelexporter",
  "displayName": "%displayName%",
  "description": "%decription%",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:json",
    "onCommand:json2excel"
  ],
  "main": "./extension.js",
  "l10n": "./l10n",
  "contributes": {
    "menus": {
      "editor/context": [
        {
          "command": "excelExporter.json2excel",
          "when": "excelExporter.isJsonArray"
        }
      ]
    },
    "commands": [
      {
        "command": "excelExporter.json2excel",
        "title": "%command.showExportSettings.title%",
        "category": "%command.category%"
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2"
  },
  "dependencies": {
    "dayjs": "^1.11.19",
    "exceljs": "^4.4.0"
  }
}
